---
/* Fussbereich: Kontaktdaten, Navigation, Rechtslinks und Entwurfshinweis. */
import { contact, nav, site } from '../data/site';
import { withBase } from '../lib/url';
const year = new Date().getFullYear();
---

<footer class="mt-24 bg-ink-900 text-ink-100">
  <div class="container-page grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Marke -->
    <div class="lg:col-span-1">
      <p class="font-serif text-2xl font-semibold text-white">Multiblatt</p>
      <p class="mt-3 text-sm leading-relaxed text-ink-100/80">
        {site.tagline}
      </p>
    </div>

    <!-- Kontakt -->
    <div>
      <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-accent-200">
        Kontakt
      </h2>
      <address class="mt-4 space-y-2 text-sm not-italic text-ink-100/85">
        <p>{contact.owner}</p>
        <p>{contact.street}<br />{contact.zip} {contact.city}</p>
        <p>
          <a class="hover:text-white" href={`tel:${contact.phoneHref}`}>
            Tel.: {contact.phoneLabel}
          </a>
        </p>
        <p>
          <a class="hover:text-white" href={`tel:${contact.mobileHref}`}>
            Mobil: {contact.mobileLabel}
          </a>
        </p>
        <p>Fax: {contact.faxLabel}</p>
        <p>
          <a class="hover:text-white" href={`mailto:${contact.email}`}>
            {contact.email}
          </a>
        </p>
      </address>
    </div>

    <!-- Navigation -->
    <div>
      <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-accent-200">
        Übersicht
      </h2>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a class="text-ink-100/85 hover:text-white" href={withBase('/#top')}>Start</a></li>
        {
          nav.map((item) => (
            <li>
              <a class="text-ink-100/85 hover:text-white" href={withBase(`/#${item.id}`)}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Öffnungszeiten -->
    <div>
      <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-accent-200">
        Sprechzeiten
      </h2>
      <ul class="mt-4 space-y-1 text-sm text-ink-100/85">
        {
          contact.hours.map((h) => (
            <li class="flex justify-between gap-4">
              <span>{h.day}</span>
              <span>{h.time}</span>
            </li>
          ))
        }
      </ul>
      <p class="mt-3 text-xs leading-relaxed text-ink-100/55">{contact.hoursNote}</p>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div
      class="container-page flex flex-col items-start justify-between gap-3 py-5 text-xs text-ink-100/60 sm:flex-row sm:items-center"
    >
      <p>© {year} {site.name} · {contact.owner}, {contact.city}</p>
      <nav aria-label="Rechtliches" class="flex items-center gap-5">
        <a class="hover:text-white" href={withBase('/impressum/')}>Impressum</a>
        <a class="hover:text-white" href={withBase('/datenschutz/')}>Datenschutz</a>
      </nav>
    </div>
    <!-- Dezenter, ehrlicher Hinweis fuer die Pitch-Vorschau -->
    <p class="container-page pb-24 text-[0.7rem] text-ink-100/40 lg:pb-6">
      Gestaltungsentwurf (Redesign-Vorschau) – nicht die offizielle Website.
    </p>
  </div>
</footer>
