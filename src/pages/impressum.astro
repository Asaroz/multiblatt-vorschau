---
/* Impressum – LAYOUT-PLATZHALTER.
   Die Pflichtangaben sind strukturell angelegt und mit den bekannten Stammdaten
   vorbefuellt. Rechtsverbindliche Vollstaendigkeit (z. B. USt-IdNr.,
   Aufsichtsbehoerde, Berufshaftpflicht) muss die Inhaberin bzw. ein
   Impressums-Generator/eine Rechtsberatung ergaenzen. */
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { contact } from '../data/site';
---

<Base title="Impressum" description="Impressum von Multiblatt – Angela Aldenhoff, Rees.">
  <PageHero
    eyebrow="Rechtliches"
    title="Impressum"
    crumbs={[{ label: 'Start', href: '/' }, { label: 'Impressum' }]}
  />

  <section class="container-prose py-16">
    <div class="prose-block mt-4 space-y-8">
      <div>
        <h2 class="text-xl font-semibold text-ink-900">Angaben gemäß § 5 DDG</h2>
        <p class="mt-3">
          {contact.company}<br />
          {contact.owner}<br />
          {contact.street}<br />
          {contact.zip} {contact.city}<br />
          {contact.country}
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-ink-900">Kontakt</h2>
        <p class="mt-3">
          Telefon: {contact.phoneLabel}<br />
          Mobil: {contact.mobileLabel}<br />
          Fax: {contact.faxLabel}<br />
          E-Mail: {contact.email}
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-ink-900">
          Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV
        </h2>
        <p class="mt-3">
          {contact.owner}<br />
          {contact.street}, {contact.zip} {contact.city}
        </p>
      </div>
    </div>
  </section>
</Base>
