---
/* Datenschutzerklärung – LAYOUT-PLATZHALTER.
   Struktur nach DSGVO ist angelegt; die positiven, technisch bereits
   umgesetzten Punkte (lokale Schriften, kein Tracking, Karte erst nach Klick)
   sind benannt. Der rechtsverbindliche Volltext muss von der Inhaberin bzw.
   ueber einen Datenschutz-Generator / eine Rechtsberatung ergaenzt werden. */
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { contact } from '../data/site';
---

<Base title="Datenschutz" description="Datenschutzhinweise von Multiblatt – datensparsam, ohne Tracking.">
  <PageHero
    eyebrow="Rechtliches"
    title="Datenschutz"
    crumbs={[{ label: 'Start', href: '/' }, { label: 'Datenschutz' }]}
  />

  <section class="container-prose py-16">
    <div class="prose-block mt-4 space-y-8">
      <div>
        <h2 class="text-xl font-semibold text-ink-900">Verantwortlicher</h2>
        <p class="mt-3">
          {contact.owner}<br />
          {contact.company}, {contact.street}, {contact.zip} {contact.city}<br />
          E-Mail: {contact.email} · Telefon: {contact.phoneLabel}
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-ink-900">Datensparsamkeit dieser Website</h2>
        <ul class="mt-3 list-disc space-y-2 pl-5">
          <li>Es werden <strong>keine Tracking- oder Marketing-Cookies</strong> gesetzt.</li>
          <li>Es ist <strong>keine Webanalyse</strong> (z.&nbsp;B. Google Analytics) eingebunden.</li>
          <li>Schriften werden <strong>lokal ausgeliefert</strong> (kein Google-Fonts-CDN).</li>
          <li>Die Karte unter „Anfahrt“ lädt <strong>erst nach aktivem Klick</strong> (Einwilligung).</li>
        </ul>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-ink-900">OpenStreetMap</h2>
        <p class="mt-3">
          Beim Laden der Karte im Bereich „Anfahrt“ wird eine Verbindung zu den
          Servern der OpenStreetMap Foundation aufgebaut; dabei kann u.&nbsp;a.
          die IP-Adresse übermittelt werden. Das Laden erfolgt ausschließlich
          nach ausdrücklicher Einwilligung (Klick).
        </p>
      </div>
    </div>
  </section>
</Base>
