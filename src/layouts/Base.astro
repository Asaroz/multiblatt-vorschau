---
/* =============================================================================
   Basis-Layout fuer alle Seiten.
   ---------------------------------------------------------------------------
   HINWEIS (Redesign-Entwurf): Dies ist ein reiner Gestaltungs-/Pitch-Entwurf
   fuer Multiblatt. Inhalte entsprechen der aktuellen Website; einzelne
   Beschreibungstexte sind als Entwurf gekennzeichnet. Die Rechtstexte
   (Impressum / Datenschutz) sind nur als Layout angelegt und muessen noch von
   der Inhaberin bzw. per Generator inhaltlich befuellt werden.
   ========================================================================== */

// Schriften lokal einbinden (self-hosted ueber @fontsource – KEINE Google-Fonts-CDN)
import '@fontsource-variable/inter';
import '@fontsource-variable/source-serif-4';
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site, contact } from '../data/site';
import { withBase } from '../lib/url';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} · ${site.name}` : `${site.name} – ${site.tagline}`;
const pageDescription =
  description ??
  'Multiblatt – Büro-Dienstleistungen & Schreibbüro von Angela Aldenhoff in Rees. Schreibdienste, vorbereitende Buchhaltung und Hilfe bei privaten Unterlagen.';

// LocalBusiness-Strukturdaten (inline, keine externen Aufrufe) – gut fuer lokale Auffindbarkeit.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: site.name,
  founder: contact.owner,
  description: pageDescription,
  email: contact.email,
  telephone: contact.phoneLabel,
  address: {
    '@type': 'PostalAddress',
    streetAddress: contact.street,
    postalCode: contact.zip,
    addressLocality: contact.city,
    addressCountry: 'DE',
  },
  areaServed: 'Rees und Umgebung',
};
---

<!doctype html>
<!--
  ============================================================================
  MULTIBLATT – REDESIGN-ENTWURF (Pitch-Vorschau)
  Dies ist NICHT die offizielle Website. Inhalte = aktuelle Seite, Gestaltung neu.
  Rechtstexte (Impressum/Datenschutz) sind Platzhalter und von der Inhaberin
  bzw. per Generator zu befuellen.
  ============================================================================
-->
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#0f1d33" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

    <!-- Open Graph (lokale Vorschau, keine externen Skripte) -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />

    <!-- Favicon-Platzhalter (Inline-SVG, kein externer Request) -->
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%230f1d33'/%3E%3Ctext x='16' y='22' font-family='Georgia,serif' font-size='18' fill='%23b9774a' text-anchor='middle'%3EM%3C/text%3E%3C/svg%3E"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- Mobile: feste Kontakt-Leiste ("sticky shoe") – telefon-/anfrage-zentriert.
         Best Practice für lokale Dienstleister: schnelle Erreichbarkeit immer sichtbar. -->
    <div
      class="js-cta-bar fixed inset-x-0 bottom-0 z-50 border-t border-line bg-paper/95 backdrop-blur lg:hidden"
      style="padding-bottom: env(safe-area-inset-bottom);"
    >
      <div class="grid grid-cols-2 gap-2 px-3 py-2.5">
        <a href={`tel:${contact.phoneHref}`} class="btn btn-secondary w-full">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.5 5.5C2.5 4 3.7 3 5.2 3h1.6c.7 0 1.3.5 1.5 1.2l.8 3c.2.6 0 1.3-.5 1.7l-1.3 1c.9 1.9 2.5 3.5 4.4 4.4l1-1.3c.4-.5 1-.7 1.7-.5l3 .8c.7.2 1.2.8 1.2 1.5v1.6c0 1.5-1 2.7-2.5 2.7C10.6 21.4 2.6 13.4 2.5 5.5Z" />
          </svg>
          Anrufen
        </a>
        <a href={withBase('/#kontakt')} class="btn btn-primary w-full">Anfrage</a>
      </div>
    </div>
  </body>
</html>
